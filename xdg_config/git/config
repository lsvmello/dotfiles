[user]
  email = lsvmello@gmail.com
  name = Leonardo Mello
[alias]
  amend = commit --amend --no-edit
  lg = log --color --graph --pretty=format:'%Cred%h%Creset%C(yellow)%d%Creset %s %Creset(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
  l = lg -10
  recent = branch --verbose --sort=-committerdate
  s = status
  ss = status --short
  undo = reset --soft HEAD^
  fixup = "!git log -n 20 --pretty=format:'%h %s' --no-merges | fzf | cut -c -7 | xargs -o git commit --fixup"
  gone = "!git fetch --prune && git branch -vv | grep ': gone]' | awk '{print $1}' | xargs -r git branch -D"
[fetch]
  prune = true
[core]
  autocrlf = input
  editor = nvim
[init]
  defaultBranch = main
[help]
  autoCorrect = 1
[pull]
  rebase = true
[rebase]
  autoStash = true
  autosquash = true
  updateRefs = true
